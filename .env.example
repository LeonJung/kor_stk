# Copy to .env and fill in. Never commit .env.
# Issued at https://apiportal.koreainvestment.com/

# mock = 모의투자, live = 실전투자
KIS_ENV=mock

KIS_APP_KEY=
KIS_APP_SECRET=

# 계좌번호 — 종합계좌(CANO) 8자리 + 상품코드(PRDT) 2자리
# 예: 12345678-01 → CANO=12345678, PRDT=01
KIS_ACCOUNT_CANO=
KIS_ACCOUNT_PRDT=01

# WebSocket 실시간 시세용 HTS ID
KIS_HTS_ID=

# Daishin CYBOS Plus on Windows PC (172.30.1.38)
DAISHIN_WIN_IP=172.30.1.38
DAISHIN_WIN_USER=owner
DAISHIN_WIN_PWD=<password>
